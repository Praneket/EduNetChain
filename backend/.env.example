# Copy this file to .env and fill in your values
# NEVER commit the actual .env file

PORT=5000
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_random_secret_string_here
ALLOWED_ORIGINS=http://localhost:5173
NODE_ENV=development

# Blockchain — Sepolia testnet via Alchemy
# Get free RPC URL at https://alchemy.com
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# The account that deployed the contract — needs Sepolia ETH for gas
# Get free Sepolia ETH at https://sepoliafaucet.com
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Address of the deployed Verification contract
CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS_HERE

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@edunetchain.com

# Web3 Storage (optional IPFS)
WEB3_STORAGE_TOKEN=your_token_here

# Cloudinary (file storage fallback)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Supabase (primary file storage)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key
